[
  {
    "surahId": 80,
    "ayahNumber": 1,
    "arabicText": "عَبَسَ وَتَوَلَّىٰٓ",
    "translationText": "He frowned and turned away."
  },
  {
    "surahId": 80,
    "ayahNumber": 2,
    "arabicText": "أَن جَآءَهُ ٱلْأَعْمَىٰ",
    "translationText": "When the blind man approached him."
  },
  {
    "surahId": 80,
    "ayahNumber": 3,
    "arabicText": "وَمَا يُدْرِيكَ لَعَلَّهُۥ يَزَّكَّىٰٓ",
    "translationText": "But how do you know? Perhaps he was seeking to purify himself."
  },
  {
    "surahId": 80,
    "ayahNumber": 4,
    "arabicText": "أَوْ يَذَّكَّرُ فَتَنفَعَهُ ٱلذِّكْرَىٰٓ",
    "translationText": "Or be reminded, and the message would benefit him."
  },
  {
    "surahId": 80,
    "ayahNumber": 5,
    "arabicText": "أَمَّا مَنِ ٱسْتَغْنَىٰ",
    "translationText": "But as for him who was indifferent."
  },
  {
    "surahId": 80,
    "ayahNumber": 6,
    "arabicText": "فَأَنتَ لَهُۥ تَصَدَّىٰ",
    "translationText": "You gave him your attention."
  },
  {
    "surahId": 80,
    "ayahNumber": 7,
    "arabicText": "وَمَا عَلَيْكَ أَلَّا يَزَّكَّىٰ",
    "translationText": "Though you are not liable if he does not purify himself."
  },
  {
    "surahId": 80,
    "ayahNumber": 8,
    "arabicText": "وَأَمَّا مَن جَآءَكَ يَسْعَىٰ",
    "translationText": "But as for him who came to you seeking."
  },
  {
    "surahId": 80,
    "ayahNumber": 9,
    "arabicText": "وَهُوَ يَخْشَىٰ",
    "translationText": "In awe."
  },
  {
    "surahId": 80,
    "ayahNumber": 10,
    "arabicText": "فَأَنتَ عَنْهُ تَلَهَّىٰ",
    "translationText": "To him you were inattentive."
  },
  {
    "surahId": 80,
    "ayahNumber": 11,
    "arabicText": "كَلَّآ إِنَّهَا تَذْكِرَةٌۭ",
    "translationText": "Do not. This is a Lesson."
  },
  {
    "surahId": 80,
    "ayahNumber": 12,
    "arabicText": "فَمَن شَآءَ ذَكَرَهُۥ",
    "translationText": "Whoever wills, shall remember it."
  },
  {
    "surahId": 80,
    "ayahNumber": 13,
    "arabicText": "فِى صُحُفٍۢ مُّكَرَّمَةٍۢ",
    "translationText": "On honorable pages."
  },
  {
    "surahId": 80,
    "ayahNumber": 14,
    "arabicText": "مَّرْفُوعَةٍۢ مُّطَهَّرَةٍۭ",
    "translationText": "Exalted and purified."
  },
  {
    "surahId": 80,
    "ayahNumber": 15,
    "arabicText": "بِأَيْدِى سَفَرَةٍۢ",
    "translationText": "By the hands of scribes."
  },
  {
    "surahId": 80,
    "ayahNumber": 16,
    "arabicText": "كِرَامٍۭ بَرَرَةٍۢ",
    "translationText": "Noble and devoted."
  },
  {
    "surahId": 80,
    "ayahNumber": 17,
    "arabicText": "قُتِلَ ٱلْإِنسَٰنُ مَآ أَكْفَرَهُۥ",
    "translationText": "Perish man! How thankless he is!"
  },
  {
    "surahId": 80,
    "ayahNumber": 18,
    "arabicText": "مِنْ أَىِّ شَىْءٍ خَلَقَهُۥ",
    "translationText": "From what did He create him?"
  },
  {
    "surahId": 80,
    "ayahNumber": 19,
    "arabicText": "مِن نُّطْفَةٍ خَلَقَهُۥ فَقَدَّرَهُۥ",
    "translationText": "From a sperm drop He created him, and enabled him."
  },
  {
    "surahId": 80,
    "ayahNumber": 20,
    "arabicText": "ثُمَّ ٱلسَّبِيلَ يَسَّرَهُۥ",
    "translationText": "Then He eased the way for him."
  },
  {
    "surahId": 80,
    "ayahNumber": 21,
    "arabicText": "ثُمَّ أَمَاتَهُۥ فَأَقْبَرَهُۥ",
    "translationText": "Then He puts him to death, and buries him."
  },
  {
    "surahId": 80,
    "ayahNumber": 22,
    "arabicText": "ثُمَّ إِذَا شَآءَ أَنشَرَهُۥ",
    "translationText": "Then, when He wills, He will resurrect him."
  },
  {
    "surahId": 80,
    "ayahNumber": 23,
    "arabicText": "كَلَّا لَمَّا يَقْضِ مَآ أَمَرَهُۥ",
    "translationText": "But no, he did not fulfill what He has commanded him."
  },
  {
    "surahId": 80,
    "ayahNumber": 24,
    "arabicText": "فَلْيَنظُرِ ٱلْإِنسَٰنُ إِلَىٰ طَعَامِهِۦٓ",
    "translationText": "Let man consider his food."
  },
  {
    "surahId": 80,
    "ayahNumber": 25,
    "arabicText": "أَنَّا صَبَبْنَا ٱلْمَآءَ صَبًّۭا",
    "translationText": "We pour down water in abundance."
  },
  {
    "surahId": 80,
    "ayahNumber": 26,
    "arabicText": "ثُمَّ شَقَقْنَا ٱلْأَرْضَ شَقًّۭا",
    "translationText": "Then crack the soil open."
  },
  {
    "surahId": 80,
    "ayahNumber": 27,
    "arabicText": "فَأَنۢبَتْنَا فِيهَا حَبًّۭا",
    "translationText": "And grow in it grains."
  },
  {
    "surahId": 80,
    "ayahNumber": 28,
    "arabicText": "وَعِنَبًۭا وَقَضْبًۭا",
    "translationText": "And grapes and herbs."
  },
  {
    "surahId": 80,
    "ayahNumber": 29,
    "arabicText": "وَزَيْتُونًۭا وَنَخْلًۭا",
    "translationText": "And olives and dates."
  },
  {
    "surahId": 80,
    "ayahNumber": 30,
    "arabicText": "وَحَدَآئِقَ غُلْبًۭا",
    "translationText": "And luscious gardens."
  },
  {
    "surahId": 80,
    "ayahNumber": 31,
    "arabicText": "وَفَٰكِهَةًۭ وَأَبًّۭا",
    "translationText": "And fruits and vegetables."
  },
  {
    "surahId": 80,
    "ayahNumber": 32,
    "arabicText": "مَّتَٰعًۭا لَّكُمْ وَلِأَنْعَٰمِكُمْ",
    "translationText": "Enjoyment for you, and for your livestock."
  },
  {
    "surahId": 80,
    "ayahNumber": 33,
    "arabicText": "فَإِذَا جَآءَتِ ٱلصَّآخَّةُ",
    "translationText": "But when the Deafening Noise comes to pass."
  },
  {
    "surahId": 80,
    "ayahNumber": 34,
    "arabicText": "يَوْمَ يَفِرُّ ٱلْمَرْءُ مِنْ أَخِيهِ",
    "translationText": "The Day when a person will flee from his brother."
  },
  {
    "surahId": 80,
    "ayahNumber": 35,
    "arabicText": "وَأُمِّهِۦ وَأَبِيهِ",
    "translationText": "And his mother and his father."
  },
  {
    "surahId": 80,
    "ayahNumber": 36,
    "arabicText": "وَصَٰحِبَتِهِۦ وَبَنِيهِ",
    "translationText": "And his consort and his children."
  },
  {
    "surahId": 80,
    "ayahNumber": 37,
    "arabicText": "لِكُلِّ ٱمْرِئٍۢ مِّنْهُمْ يَوْمَئِذٍۢ شَأْنٌۭ يُغْنِيهِ",
    "translationText": "Every one of them, on that Day, will have enough to preoccupy him."
  },
  {
    "surahId": 80,
    "ayahNumber": 38,
    "arabicText": "وُجُوهٌۭ يَوْمَئِذٍۢ مُّسْفِرَةٌۭ",
    "translationText": "Faces on that Day will be radiant."
  },
  {
    "surahId": 80,
    "ayahNumber": 39,
    "arabicText": "ضَاحِكَةٌۭ مُّسْتَبْشِرَةٌۭ",
    "translationText": "Laughing and rejoicing."
  },
  {
    "surahId": 80,
    "ayahNumber": 40,
    "arabicText": "وَوُجُوهٌۭ يَوْمَئِذٍ عَلَيْهَا غَبَرَةٌۭ",
    "translationText": "And Faces on that Day will be covered with misery."
  },
  {
    "surahId": 80,
    "ayahNumber": 41,
    "arabicText": "تَرْهَقُهَا قَتَرَةٌ",
    "translationText": "Overwhelmed by remorse."
  },
  {
    "surahId": 80,
    "ayahNumber": 42,
    "arabicText": "أُو۟لَٰٓئِكَ هُمُ ٱلْكَفَرَةُ ٱلْفَجَرَةُ",
    "translationText": "These are the faithless, the vicious."
  }
]