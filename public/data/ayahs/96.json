  },
  {
    "surahId": 96,
    "ayahNumber": 6,
    "arabicText": "كَلَّآ إِنَّ ٱلْإِنسَٰنَ لَيَطْغَىٰٓ",
    "translationText": "In fact, man oversteps all bounds."
  },
  {
