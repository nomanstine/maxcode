[
  {
    "surahId": 75,
    "ayahNumber": 1,
    "arabicText": "لَآ أُقْسِمُ بِيَوْمِ ٱلْقِيَٰمَةِ",
    "translationText": "I swear by the Day of Resurrection."
  },
  {
    "surahId": 75,
    "ayahNumber": 2,
    "arabicText": "وَلَآ أُقْسِمُ بِٱلنَّفْسِ ٱللَّوَّامَةِ",
    "translationText": "And I swear by the blaming soul."
  },
  {
    "surahId": 75,
    "ayahNumber": 3,
    "arabicText": "أَيَحْسَبُ ٱلْإِنسَٰنُ أَلَّن نَّجْمَعَ عِظَامَهُۥ",
    "translationText": "Does man think that We will not reassemble his bones?"
  },
  {
    "surahId": 75,
    "ayahNumber": 4,
    "arabicText": "بَلَىٰ قَٰدِرِينَ عَلَىٰٓ أَن نُّسَوِّىَ بَنَانَهُۥ",
    "translationText": "Yes indeed; We are Able to reconstruct his fingertips."
  },
  {
    "surahId": 75,
    "ayahNumber": 5,
    "arabicText": "بَلْ يُرِيدُ ٱلْإِنسَٰنُ لِيَفْجُرَ أَمَامَهُۥ",
    "translationText": "But man wants to deny what is ahead of him."
  },
  {
    "surahId": 75,
    "ayahNumber": 6,
    "arabicText": "يَسْـَٔلُ أَيَّانَ يَوْمُ ٱلْقِيَٰمَةِ",
    "translationText": "He asks, \"When is the Day of Resurrection?\""
  },
  {
    "surahId": 75,
    "ayahNumber": 7,
    "arabicText": "فَإِذَا بَرِقَ ٱلْبَصَرُ",
    "translationText": "When vision is dazzled."
  },
  {
    "surahId": 75,
    "ayahNumber": 8,
    "arabicText": "وَخَسَفَ ٱلْقَمَرُ",
    "translationText": "And the moon is eclipsed."
  },
  {
    "surahId": 75,
    "ayahNumber": 9,
    "arabicText": "وَجُمِعَ ٱلشَّمْسُ وَٱلْقَمَرُ",
    "translationText": "And the sun and the moon are joined together."
  },
  {
    "surahId": 75,
    "ayahNumber": 10,
    "arabicText": "يَقُولُ ٱلْإِنسَٰنُ يَوْمَئِذٍ أَيْنَ ٱلْمَفَرُّ",
    "translationText": "On that Day, man will say, \"Where is the escape?\""
  },
  {
    "surahId": 75,
    "ayahNumber": 11,
    "arabicText": "كَلَّا لَا وَزَرَ",
    "translationText": "No indeed! There is no refuge."
  },
  {
    "surahId": 75,
    "ayahNumber": 12,
    "arabicText": "إِلَىٰ رَبِّكَ يَوْمَئِذٍ ٱلْمُسْتَقَرُّ",
    "translationText": "To your Lord on that Day is the settlement."
  },
  {
    "surahId": 75,
    "ayahNumber": 13,
    "arabicText": "يُنَبَّؤُا۟ ٱلْإِنسَٰنُ يَوْمَئِذٍۭ بِمَا قَدَّمَ وَأَخَّرَ",
    "translationText": "On that Day man will be informed of everything he put forward, and everything he left behind."
  },
  {
    "surahId": 75,
    "ayahNumber": 14,
    "arabicText": "بَلِ ٱلْإِنسَٰنُ عَلَىٰ نَفْسِهِۦ بَصِيرَةٌۭ",
    "translationText": "And man will be evidence against himself."
  },
  {
    "surahId": 75,
    "ayahNumber": 15,
    "arabicText": "وَلَوْ أَلْقَىٰ مَعَاذِيرَهُۥ",
    "translationText": "Even as he presents his excuses."
  },
  {
    "surahId": 75,
    "ayahNumber": 16,
    "arabicText": "لَا تُحَرِّكْ بِهِۦ لِسَانَكَ لِتَعْجَلَ بِهِۦٓ",
    "translationText": "Do not wag your tongue with it, to hurry on with it."
  },
  {
    "surahId": 75,
    "ayahNumber": 17,
    "arabicText": "إِنَّ عَلَيْنَا جَمْعَهُۥ وَقُرْءَانَهُۥ",
    "translationText": "Upon Us is its collection and its recitation."
  },
  {
    "surahId": 75,
    "ayahNumber": 18,
    "arabicText": "فَإِذَا قَرَأْنَٰهُ فَٱتَّبِعْ قُرْءَانَهُۥ",
    "translationText": "Then, when We have recited it, follow its recitation."
  },
  {
    "surahId": 75,
    "ayahNumber": 19,
    "arabicText": "ثُمَّ إِنَّ عَلَيْنَا بَيَانَهُۥ",
    "translationText": "Then upon Us is its explanation."
  },
  {
    "surahId": 75,
    "ayahNumber": 20,
    "arabicText": "كَلَّا بَلْ تُحِبُّونَ ٱلْعَاجِلَةَ",
    "translationText": "Alas, you love the fleeting life."
  },
  {
    "surahId": 75,
    "ayahNumber": 21,
    "arabicText": "وَتَذَرُونَ ٱلْءَاخِرَةَ",
    "translationText": "And you disregard the Hereafter."
  },
  {
    "surahId": 75,
    "ayahNumber": 22,
    "arabicText": "وُجُوهٌۭ يَوْمَئِذٍۢ نَّاضِرَةٌ",
    "translationText": "Faces on that Day will be radiant."
  },
  {
    "surahId": 75,
    "ayahNumber": 23,
    "arabicText": "إِلَىٰ رَبِّهَا نَاظِرَةٌۭ",
    "translationText": "Looking towards their Lord."
  },
  {
    "surahId": 75,
    "ayahNumber": 24,
    "arabicText": "وَوُجُوهٌۭ يَوْمَئِذٍۭ بَاسِرَةٌۭ",
    "translationText": "And faces on that Day will be gloomy."
  },
  {
    "surahId": 75,
    "ayahNumber": 25,
    "arabicText": "تَظُنُّ أَن يُفْعَلَ بِهَا فَاقِرَةٌۭ",
    "translationText": "Realizing that a back-breaker has befallen them."
  },
  {
    "surahId": 75,
    "ayahNumber": 26,
    "arabicText": "كَلَّآ إِذَا بَلَغَتِ ٱلتَّرَاقِىَ",
    "translationText": "Indeed, when it has reached the breast-bones."
  },
  {
    "surahId": 75,
    "ayahNumber": 27,
    "arabicText": "وَقِيلَ مَنْ ۜ رَاقٍۢ",
    "translationText": "And it is said, \"Who is the healer?\""
  },
  {
    "surahId": 75,
    "ayahNumber": 28,
    "arabicText": "وَظَنَّ أَنَّهُ ٱلْفِرَاقُ",
    "translationText": "And He realizes that it is the parting."
  },
  {
    "surahId": 75,
    "ayahNumber": 29,
    "arabicText": "وَٱلْتَفَّتِ ٱلسَّاقُ بِٱلسَّاقِ",
    "translationText": "And leg is entwined with leg."
  },
  {
    "surahId": 75,
    "ayahNumber": 30,
    "arabicText": "إِلَىٰ رَبِّكَ يَوْمَئِذٍ ٱلْمَسَاقُ",
    "translationText": "To your Lord on that Day is the drive."
  },
  {
    "surahId": 75,
    "ayahNumber": 31,
    "arabicText": "فَلَا صَدَّقَ وَلَا صَلَّىٰ",
    "translationText": "He neither believed nor prayed."
  },
  {
    "surahId": 75,
    "ayahNumber": 32,
    "arabicText": "وَلَٰكِن كَذَّبَ وَتَوَلَّىٰ",
    "translationText": "But he denied and turned away."
  },
  {
    "surahId": 75,
    "ayahNumber": 33,
    "arabicText": "ثُمَّ ذَهَبَ إِلَىٰٓ أَهْلِهِۦ يَتَمَطَّىٰٓ",
    "translationText": "Then he went to his family, full of pride."
  },
  {
    "surahId": 75,
    "ayahNumber": 34,
    "arabicText": "أَوْلَىٰ لَكَ فَأَوْلَىٰ",
    "translationText": "Woe to you; and woe."
  },
  {
    "surahId": 75,
    "ayahNumber": 35,
    "arabicText": "ثُمَّ أَوْلَىٰ لَكَ فَأَوْلَىٰٓ",
    "translationText": "Then again: Woe to you; and woe."
  },
  {
    "surahId": 75,
    "ayahNumber": 36,
    "arabicText": "أَيَحْسَبُ ٱلْإِنسَٰنُ أَن يُتْرَكَ سُدًى",
    "translationText": "Does man think that he will be left without purpose?"
  },
  {
    "surahId": 75,
    "ayahNumber": 37,
    "arabicText": "أَلَمْ يَكُ نُطْفَةًۭ مِّن مَّنِىٍّۢ يُمْنَىٰ",
    "translationText": "Was he not a drop of ejaculated semen?"
  },
  {
    "surahId": 75,
    "ayahNumber": 38,
    "arabicText": "ثُمَّ كَانَ عَلَقَةًۭ فَخَلَقَ فَسَوَّىٰ",
    "translationText": "Then he became a clot. And He created and proportioned?"
  },
  {
    "surahId": 75,
    "ayahNumber": 39,
    "arabicText": "فَجَعَلَ مِنْهُ ٱلزَّوْجَيْنِ ٱلذَّكَرَ وَٱلْأُنثَىٰٓ",
    "translationText": "And made of him the two sexes, the male and the female?"
  },
  {
    "surahId": 75,
    "ayahNumber": 40,
    "arabicText": "أَلَيْسَ ذَٰلِكَ بِقَٰدِرٍ عَلَىٰٓ أَن يُحْۦِىَ ٱلْمَوْتَىٰ",
    "translationText": "Is He not Able to revive the dead?"
  }
]