[
  {
    "surahId": 104,
    "ayahNumber": 1,
    "arabicText": "وَيْلٌۭ لِّكُلِّ هُمَزَةٍۢ لُّمَزَةٍ",
    "translationText": "Woe to every slanderer backbiter."
  },
  {
    "surahId": 104,
    "ayahNumber": 2,
    "arabicText": "ٱلَّذِى جَمَعَ مَالًۭا وَعَدَّدَهُۥ",
    "translationText": "Who gathers wealth and counts it over."
  },
  {
    "surahId": 104,
    "ayahNumber": 3,
    "arabicText": "يَحْسَبُ أَنَّ مَالَهُۥٓ أَخْلَدَهُۥ",
    "translationText": "Thinking that his wealth has made him immortal."
  },
  {
    "surahId": 104,
    "ayahNumber": 4,
    "arabicText": "كَلَّا ۖ لَيُنۢبَذَنَّ فِى ٱلْحُطَمَةِ",
    "translationText": "By no means. He will be thrown into the Crusher."
  },
  {
    "surahId": 104,
    "ayahNumber": 5,
    "arabicText": "وَمَآ أَدْرَىٰكَ مَا ٱلْحُطَمَةُ",
    "translationText": "And what will make you realize what the Crusher is?"
  },
  {
    "surahId": 104,
    "ayahNumber": 6,
    "arabicText": "نَارُ ٱللَّهِ ٱلْمُوقَدَةُ",
    "translationText": "God's kindled Fire."
  },
  {
    "surahId": 104,
    "ayahNumber": 7,
    "arabicText": "ٱلَّتِى تَطَّلِعُ عَلَى ٱلْأَفْـِٔدَةِ",
    "translationText": "That laps to the hearts."
  },
  {
    "surahId": 104,
    "ayahNumber": 8,
    "arabicText": "إِنَّهَا عَلَيْهِم مُّؤْصَدَةٌۭ",
    "translationText": "It closes in on them."
  },
  {
    "surahId": 104,
    "ayahNumber": 9,
    "arabicText": "فِى عَمَدٍۢ مُّمَدَّدَةٍۭ",
    "translationText": "In extended columns."
  }
]