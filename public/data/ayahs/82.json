[
  {
    "surahId": 82,
    "ayahNumber": 1,
    "arabicText": "إِذَا ٱلسَّمَآءُ ٱنفَطَرَتْ",
    "translationText": "When the sky breaks apart."
  },
  {
    "surahId": 82,
    "ayahNumber": 2,
    "arabicText": "وَإِذَا ٱلْكَوَاكِبُ ٱنتَثَرَتْ",
    "translationText": "When the planets are scattered."
  },
  {
    "surahId": 82,
    "ayahNumber": 3,
    "arabicText": "وَإِذَا ٱلْبِحَارُ فُجِّرَتْ",
    "translationText": "When the oceans are exploded."
  },
  {
    "surahId": 82,
    "ayahNumber": 4,
    "arabicText": "وَإِذَا ٱلْقُبُورُ بُعْثِرَتْ",
    "translationText": "When the tombs are strewn around."
  },
  {
    "surahId": 82,
    "ayahNumber": 5,
    "arabicText": "عَلِمَتْ نَفْسٌۭ مَّا قَدَّمَتْ وَأَخَّرَتْ",
    "translationText": "Each soul will know what it has advanced, and what it has deferred."
  },
  {
    "surahId": 82,
    "ayahNumber": 6,
    "arabicText": "يَٰٓأَيُّهَا ٱلْإِنسَٰنُ مَا غَرَّكَ بِرَبِّكَ ٱلْكَرِيمِ",
    "translationText": "O man! What deluded you concerning your Lord, the Most Generous?"
  },
  {
    "surahId": 82,
    "ayahNumber": 7,
    "arabicText": "ٱلَّذِى خَلَقَكَ فَسَوَّىٰكَ فَعَدَلَكَ",
    "translationText": "He Who created you, and formed you, and proportioned you?"
  },
  {
    "surahId": 82,
    "ayahNumber": 8,
    "arabicText": "فِىٓ أَىِّ صُورَةٍۢ مَّا شَآءَ رَكَّبَكَ",
    "translationText": "In whatever shape He willed, He assembled you."
  },
  {
    "surahId": 82,
    "ayahNumber": 9,
    "arabicText": "كَلَّا بَلْ تُكَذِّبُونَ بِٱلدِّينِ",
    "translationText": "But you reject the religion."
  },
  {
    "surahId": 82,
    "ayahNumber": 10,
    "arabicText": "وَإِنَّ عَلَيْكُمْ لَحَٰفِظِينَ",
    "translationText": "Though over you are watchers."
  },
  {
    "surahId": 82,
    "ayahNumber": 11,
    "arabicText": "كِرَامًۭا كَٰتِبِينَ",
    "translationText": "Honest recorders."
  },
  {
    "surahId": 82,
    "ayahNumber": 12,
    "arabicText": "يَعْلَمُونَ مَا تَفْعَلُونَ",
    "translationText": "They know everything you do."
  },
  {
    "surahId": 82,
    "ayahNumber": 13,
    "arabicText": "إِنَّ ٱلْأَبْرَارَ لَفِى نَعِيمٍۢ",
    "translationText": "The virtuous will be in bliss."
  },
  {
    "surahId": 82,
    "ayahNumber": 14,
    "arabicText": "وَإِنَّ ٱلْفُجَّارَ لَفِى جَحِيمٍۢ",
    "translationText": "While the wicked will be in Hell."
  },
  {
    "surahId": 82,
    "ayahNumber": 15,
    "arabicText": "يَصْلَوْنَهَا يَوْمَ ٱلدِّينِ",
    "translationText": "They will enter it on the Day of Justice."
  },
  {
    "surahId": 82,
    "ayahNumber": 16,
    "arabicText": "وَمَا هُمْ عَنْهَا بِغَآئِبِينَ",
    "translationText": "And they will not be absent from it."
  },
  {
    "surahId": 82,
    "ayahNumber": 17,
    "arabicText": "وَمَآ أَدْرَىٰكَ مَا يَوْمُ ٱلدِّينِ",
    "translationText": "But what will convey to you what the Day of Justice is?"
  },
  {
    "surahId": 82,
    "ayahNumber": 18,
    "arabicText": "ثُمَّ مَآ أَدْرَىٰكَ مَا يَوْمُ ٱلدِّينِ",
    "translationText": "Then again, what will convey to you what the Day of Justice is?"
  },
  {
    "surahId": 82,
    "ayahNumber": 19,
    "arabicText": "يَوْمَ لَا تَمْلِكُ نَفْسٌۭ لِّنَفْسٍۢ شَيْـًۭٔا ۖ وَٱلْأَمْرُ يَوْمَئِذٍۢ لِّلَّهِ",
    "translationText": "The Day when no soul will avail another soul anything; and the decision on that Day is God's."
  }
]