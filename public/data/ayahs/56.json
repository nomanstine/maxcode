[
  {
    "surahId": 56,
    "ayahNumber": 1,
    "arabicText": "إِذَا وَقَعَتِ ٱلْوَاقِعَةُ",
    "translationText": "When the inevitable occurs."
  },
  {
    "surahId": 56,
    "ayahNumber": 2,
    "arabicText": "لَيْسَ لِوَقْعَتِهَا كَاذِبَةٌ",
    "translationText": "Of its occurrence, there is no denial."
  },
  {
    "surahId": 56,
    "ayahNumber": 3,
    "arabicText": "خَافِضَةٌۭ رَّافِعَةٌ",
    "translationText": "Bringing low, raising high."
  },
  {
    "surahId": 56,
    "ayahNumber": 4,
    "arabicText": "إِذَا رُجَّتِ ٱلْأَرْضُ رَجًّۭا",
    "translationText": "When the earth is shaken with a shock."
  },
  {
    "surahId": 56,
    "ayahNumber": 5,
    "arabicText": "وَبُسَّتِ ٱلْجِبَالُ بَسًّۭا",
    "translationText": "And the mountains are crushed and crumbled."
  },
  {
    "surahId": 56,
    "ayahNumber": 6,
    "arabicText": "فَكَانَتْ هَبَآءًۭ مُّنۢبَثًّۭا",
    "translationText": "And they become scattered dust."
  },
  {
    "surahId": 56,
    "ayahNumber": 7,
    "arabicText": "وَكُنتُمْ أَزْوَٰجًۭا ثَلَٰثَةًۭ",
    "translationText": "And you become three classes."
  },
  {
    "surahId": 56,
    "ayahNumber": 8,
    "arabicText": "فَأَصْحَٰبُ ٱلْمَيْمَنَةِ مَآ أَصْحَٰبُ ٱلْمَيْمَنَةِ",
    "translationText": "Those on the Right-what of those on the Right?"
  },
  {
    "surahId": 56,
    "ayahNumber": 9,
    "arabicText": "وَأَصْحَٰبُ ٱلْمَشْـَٔمَةِ مَآ أَصْحَٰبُ ٱلْمَشْـَٔمَةِ",
    "translationText": "And those on the Left-what of those on the Left?"
  },
  {
    "surahId": 56,
    "ayahNumber": 10,
    "arabicText": "وَٱلسَّٰبِقُونَ ٱلسَّٰبِقُونَ",
    "translationText": "And the forerunners, the forerunners."
  },
  {
    "surahId": 56,
    "ayahNumber": 11,
    "arabicText": "أُو۟لَٰٓئِكَ ٱلْمُقَرَّبُونَ",
    "translationText": "Those are the nearest."
  },
  {
    "surahId": 56,
    "ayahNumber": 12,
    "arabicText": "فِى جَنَّٰتِ ٱلنَّعِيمِ",
    "translationText": "In the Gardens of Bliss."
  },
  {
    "surahId": 56,
    "ayahNumber": 13,
    "arabicText": "ثُلَّةٌۭ مِّنَ ٱلْأَوَّلِينَ",
    "translationText": "A throng from the ancients."
  },
  {
    "surahId": 56,
    "ayahNumber": 14,
    "arabicText": "وَقَلِيلٌۭ مِّنَ ٱلْءَاخِرِينَ",
    "translationText": "And a small band from the latecomers."
  },
  {
    "surahId": 56,
    "ayahNumber": 15,
    "arabicText": "عَلَىٰ سُرُرٍۢ مَّوْضُونَةٍۢ",
    "translationText": "On luxurious furnishings."
  },
  {
    "surahId": 56,
    "ayahNumber": 16,
    "arabicText": "مُّتَّكِـِٔينَ عَلَيْهَا مُتَقَٰبِلِينَ",
    "translationText": "Reclining on them, facing one another."
  },
  {
    "surahId": 56,
    "ayahNumber": 17,
    "arabicText": "يَطُوفُ عَلَيْهِمْ وِلْدَٰنٌۭ مُّخَلَّدُونَ",
    "translationText": "Serving them will be immortalized youth."
  },
  {
    "surahId": 56,
    "ayahNumber": 18,
    "arabicText": "بِأَكْوَابٍۢ وَأَبَارِيقَ وَكَأْسٍۢ مِّن مَّعِينٍۢ",
    "translationText": "With cups, pitchers, and sparkling drinks."
  },
  {
    "surahId": 56,
    "ayahNumber": 19,
    "arabicText": "لَّا يُصَدَّعُونَ عَنْهَا وَلَا يُنزِفُونَ",
    "translationText": "Causing them neither headache, nor intoxication."
  },
  {
    "surahId": 56,
    "ayahNumber": 20,
    "arabicText": "وَفَٰكِهَةٍۢ مِّمَّا يَتَخَيَّرُونَ",
    "translationText": "And fruits of their choice."
  },
  {
    "surahId": 56,
    "ayahNumber": 21,
    "arabicText": "وَلَحْمِ طَيْرٍۢ مِّمَّا يَشْتَهُونَ",
    "translationText": "And meat of birds that they may desire."
  },
  {
    "surahId": 56,
    "ayahNumber": 22,
    "arabicText": "وَحُورٌ عِينٌۭ",
    "translationText": "And lovely companions."
  },
  {
    "surahId": 56,
    "ayahNumber": 23,
    "arabicText": "كَأَمْثَٰلِ ٱللُّؤْلُؤِ ٱلْمَكْنُونِ",
    "translationText": "The likenesses of treasured pearls."
  },
  {
    "surahId": 56,
    "ayahNumber": 24,
    "arabicText": "جَزَآءًۢ بِمَا كَانُوا۟ يَعْمَلُونَ",
    "translationText": "As a reward for what they used to do."
  },
  {
    "surahId": 56,
    "ayahNumber": 25,
    "arabicText": "لَا يَسْمَعُونَ فِيهَا لَغْوًۭا وَلَا تَأْثِيمًا",
    "translationText": "Therein they will hear no nonsense, and no accusations."
  },
  {
    "surahId": 56,
    "ayahNumber": 26,
    "arabicText": "إِلَّا قِيلًۭا سَلَٰمًۭا سَلَٰمًۭا",
    "translationText": "But only the greeting: \"Peace, peace.\""
  },
  {
    "surahId": 56,
    "ayahNumber": 27,
    "arabicText": "وَأَصْحَٰبُ ٱلْيَمِينِ مَآ أَصْحَٰبُ ٱلْيَمِينِ",
    "translationText": "And those on the Right-what of those on the Right?"
  },
  {
    "surahId": 56,
    "ayahNumber": 28,
    "arabicText": "فِى سِدْرٍۢ مَّخْضُودٍۢ",
    "translationText": "In lush orchards."
  },
  {
    "surahId": 56,
    "ayahNumber": 29,
    "arabicText": "وَطَلْحٍۢ مَّنضُودٍۢ",
    "translationText": "And sweet-smelling plants."
  },
  {
    "surahId": 56,
    "ayahNumber": 30,
    "arabicText": "وَظِلٍّۢ مَّمْدُودٍۢ",
    "translationText": "And extended shade."
  },
  {
    "surahId": 56,
    "ayahNumber": 31,
    "arabicText": "وَمَآءٍۢ مَّسْكُوبٍۢ",
    "translationText": "And outpouring water."
  },
  {
    "surahId": 56,
    "ayahNumber": 32,
    "arabicText": "وَفَٰكِهَةٍۢ كَثِيرَةٍۢ",
    "translationText": "And abundant fruit."
  },
  {
    "surahId": 56,
    "ayahNumber": 33,
    "arabicText": "لَّا مَقْطُوعَةٍۢ وَلَا مَمْنُوعَةٍۢ",
    "translationText": "Neither withheld, nor forbidden."
  },
  {
    "surahId": 56,
    "ayahNumber": 34,
    "arabicText": "وَفُرُشٍۢ مَّرْفُوعَةٍ",
    "translationText": "And uplifted mattresses."
  },
  {
    "surahId": 56,
    "ayahNumber": 35,
    "arabicText": "إِنَّآ أَنشَأْنَٰهُنَّ إِنشَآءًۭ",
    "translationText": "We have created them of special creation."
  },
  {
    "surahId": 56,
    "ayahNumber": 36,
    "arabicText": "فَجَعَلْنَٰهُنَّ أَبْكَارًا",
    "translationText": "And made them virgins."
  },
  {
    "surahId": 56,
    "ayahNumber": 37,
    "arabicText": "عُرُبًا أَتْرَابًۭا",
    "translationText": "Tender and un-aging."
  },
  {
    "surahId": 56,
    "ayahNumber": 38,
    "arabicText": "لِّأَصْحَٰبِ ٱلْيَمِينِ",
    "translationText": "For those on the Right."
  },
  {
    "surahId": 56,
    "ayahNumber": 39,
    "arabicText": "ثُلَّةٌۭ مِّنَ ٱلْأَوَّلِينَ",
    "translationText": "A throng from the ancients."
  },
  {
    "surahId": 56,
    "ayahNumber": 40,
    "arabicText": "وَثُلَّةٌۭ مِّنَ ٱلْءَاخِرِينَ",
    "translationText": "And a throng from the latecomers."
  },
  {
    "surahId": 56,
    "ayahNumber": 41,
    "arabicText": "وَأَصْحَٰبُ ٱلشِّمَالِ مَآ أَصْحَٰبُ ٱلشِّمَالِ",
    "translationText": "And those on the Left-what of those on the Left?"
  },
  {
    "surahId": 56,
    "ayahNumber": 42,
    "arabicText": "فِى سَمُومٍۢ وَحَمِيمٍۢ",
    "translationText": "Amid searing wind and boiling water."
  },
  {
    "surahId": 56,
    "ayahNumber": 43,
    "arabicText": "وَظِلٍّۢ مِّن يَحْمُومٍۢ",
    "translationText": "And a shadow of thick smoke."
  },
  {
    "surahId": 56,
    "ayahNumber": 44,
    "arabicText": "لَّا بَارِدٍۢ وَلَا كَرِيمٍ",
    "translationText": "Neither cool, nor refreshing."
  },
  {
    "surahId": 56,
    "ayahNumber": 45,
    "arabicText": "إِنَّهُمْ كَانُوا۟ قَبْلَ ذَٰلِكَ مُتْرَفِينَ",
    "translationText": "They had lived before that in luxury."
  },
  {
    "surahId": 56,
    "ayahNumber": 46,
    "arabicText": "وَكَانُوا۟ يُصِرُّونَ عَلَى ٱلْحِنثِ ٱلْعَظِيمِ",
    "translationText": "And they used to persist in immense wrongdoing."
  },
  {
    "surahId": 56,
    "ayahNumber": 47,
    "arabicText": "وَكَانُوا۟ يَقُولُونَ أَئِذَا مِتْنَا وَكُنَّا تُرَابًۭا وَعِظَٰمًا أَءِنَّا لَمَبْعُوثُونَ",
    "translationText": "And they used to say, \"When we are dead and turned into dust and bones, are we to be resurrected?"
  },
  {
    "surahId": 56,
    "ayahNumber": 48,
    "arabicText": "أَوَءَابَآؤُنَا ٱلْأَوَّلُونَ",
    "translationText": "And our ancient ancestors too?\""
  },
  {
    "surahId": 56,
    "ayahNumber": 49,
    "arabicText": "قُلْ إِنَّ ٱلْأَوَّلِينَ وَٱلْءَاخِرِينَ",
    "translationText": "Say, \"The first and the last."
  },
  {
    "surahId": 56,
    "ayahNumber": 50,
    "arabicText": "لَمَجْمُوعُونَ إِلَىٰ مِيقَٰتِ يَوْمٍۢ مَّعْلُومٍۢ",
    "translationText": "Will be gathered for the appointment of a familiar Day.\""
  },
  {
    "surahId": 56,
    "ayahNumber": 51,
    "arabicText": "ثُمَّ إِنَّكُمْ أَيُّهَا ٱلضَّآلُّونَ ٱلْمُكَذِّبُونَ",
    "translationText": "Then you, you misguided, who deny the truth."
  },
  {
    "surahId": 56,
    "ayahNumber": 52,
    "arabicText": "لَءَاكِلُونَ مِن شَجَرٍۢ مِّن زَقُّومٍۢ",
    "translationText": "Will be eating from the Tree of Bitterness."
  },
  {
    "surahId": 56,
    "ayahNumber": 53,
    "arabicText": "فَمَالِـُٔونَ مِنْهَا ٱلْبُطُونَ",
    "translationText": "Will be filling your bellies with it."
  },
  {
    "surahId": 56,
    "ayahNumber": 54,
    "arabicText": "فَشَٰرِبُونَ عَلَيْهِ مِنَ ٱلْحَمِيمِ",
    "translationText": "Will be drinking on top of it boiling water."
  },
  {
    "surahId": 56,
    "ayahNumber": 55,
    "arabicText": "فَشَٰرِبُونَ شُرْبَ ٱلْهِيمِ",
    "translationText": "Drinking like thirsty camels drink."
  },
  {
    "surahId": 56,
    "ayahNumber": 56,
    "arabicText": "هَٰذَا نُزُلُهُمْ يَوْمَ ٱلدِّينِ",
    "translationText": "That is their hospitality on the Day of Retribution."
  },
  {
    "surahId": 56,
    "ayahNumber": 57,
    "arabicText": "نَحْنُ خَلَقْنَٰكُمْ فَلَوْلَا تُصَدِّقُونَ",
    "translationText": "We created you-if only you would believe!"
  },
  {
    "surahId": 56,
    "ayahNumber": 58,
    "arabicText": "أَفَرَءَيْتُم مَّا تُمْنُونَ",
    "translationText": "Have you seen what you ejaculate?"
  },
  {
    "surahId": 56,
    "ayahNumber": 59,
    "arabicText": "ءَأَنتُمْ تَخْلُقُونَهُۥٓ أَمْ نَحْنُ ٱلْخَٰلِقُونَ",
    "translationText": "Is it you who create it, or are We the Creator?"
  },
  {
    "surahId": 56,
    "ayahNumber": 60,
    "arabicText": "نَحْنُ قَدَّرْنَا بَيْنَكُمُ ٱلْمَوْتَ وَمَا نَحْنُ بِمَسْبُوقِينَ",
    "translationText": "We have decreed death among you, and We will not be outstripped."
  },
  {
    "surahId": 56,
    "ayahNumber": 61,
    "arabicText": "عَلَىٰٓ أَن نُّبَدِّلَ أَمْثَٰلَكُمْ وَنُنشِئَكُمْ فِى مَا لَا تَعْلَمُونَ",
    "translationText": "In replacing you with your likes, and transforming you into what you do not know."
  },
  {
    "surahId": 56,
    "ayahNumber": 62,
    "arabicText": "وَلَقَدْ عَلِمْتُمُ ٱلنَّشْأَةَ ٱلْأُولَىٰ فَلَوْلَا تَذَكَّرُونَ",
    "translationText": "You have known the first formation; if only you would remember."
  },
  {
    "surahId": 56,
    "ayahNumber": 63,
    "arabicText": "أَفَرَءَيْتُم مَّا تَحْرُثُونَ",
    "translationText": "Have you seen what you cultivate?"
  },
  {
    "surahId": 56,
    "ayahNumber": 64,
    "arabicText": "ءَأَنتُمْ تَزْرَعُونَهُۥٓ أَمْ نَحْنُ ٱلزَّٰرِعُونَ",
    "translationText": "Is it you who make it grow, or are We the Grower?"
  },
  {
    "surahId": 56,
    "ayahNumber": 65,
    "arabicText": "لَوْ نَشَآءُ لَجَعَلْنَٰهُ حُطَٰمًۭا فَظَلْتُمْ تَفَكَّهُونَ",
    "translationText": "If We will, We can turn it into rubble; then you will lament."
  },
  {
    "surahId": 56,
    "ayahNumber": 66,
    "arabicText": "إِنَّا لَمُغْرَمُونَ",
    "translationText": "\"We are penalized."
  },
  {
    "surahId": 56,
    "ayahNumber": 67,
    "arabicText": "بَلْ نَحْنُ مَحْرُومُونَ",
    "translationText": "No, we are being deprived.\""
  },
  {
    "surahId": 56,
    "ayahNumber": 68,
    "arabicText": "أَفَرَءَيْتُمُ ٱلْمَآءَ ٱلَّذِى تَشْرَبُونَ",
    "translationText": "Have you seen the water you drink?"
  },
  {
    "surahId": 56,
    "ayahNumber": 69,
    "arabicText": "ءَأَنتُمْ أَنزَلْتُمُوهُ مِنَ ٱلْمُزْنِ أَمْ نَحْنُ ٱلْمُنزِلُونَ",
    "translationText": "Is it you who sent it down from the clouds, or are We the Sender?"
  },
  {
    "surahId": 56,
    "ayahNumber": 70,
    "arabicText": "لَوْ نَشَآءُ جَعَلْنَٰهُ أُجَاجًۭا فَلَوْلَا تَشْكُرُونَ",
    "translationText": "If We will, We can make it salty. Will you not be thankful?"
  },
  {
    "surahId": 56,
    "ayahNumber": 71,
    "arabicText": "أَفَرَءَيْتُمُ ٱلنَّارَ ٱلَّتِى تُورُونَ",
    "translationText": "Have you seen the fire you kindle?"
  },
  {
    "surahId": 56,
    "ayahNumber": 72,
    "arabicText": "ءَأَنتُمْ أَنشَأْتُمْ شَجَرَتَهَآ أَمْ نَحْنُ ٱلْمُنشِـُٔونَ",
    "translationText": "Is it you who produce its tree, or are We the Producer?"
  },
  {
    "surahId": 56,
    "ayahNumber": 73,
    "arabicText": "نَحْنُ جَعَلْنَٰهَا تَذْكِرَةًۭ وَمَتَٰعًۭا لِّلْمُقْوِينَ",
    "translationText": "We have made it a reminder, and a comfort for the users."
  },
  {
    "surahId": 56,
    "ayahNumber": 74,
    "arabicText": "فَسَبِّحْ بِٱسْمِ رَبِّكَ ٱلْعَظِيمِ",
    "translationText": "So glorify the Name of your Great Lord."
  },
  {
    "surahId": 56,
    "ayahNumber": 75,
    "arabicText": "۞ فَلَآ أُقْسِمُ بِمَوَٰقِعِ ٱلنُّجُومِ",
    "translationText": "I swear by the locations of the stars."
  },
  {
    "surahId": 56,
    "ayahNumber": 76,
    "arabicText": "وَإِنَّهُۥ لَقَسَمٌۭ لَّوْ تَعْلَمُونَ عَظِيمٌ",
    "translationText": "It is an oath, if you only knew, that is tremendous."
  },
  {
    "surahId": 56,
    "ayahNumber": 77,
    "arabicText": "إِنَّهُۥ لَقُرْءَانٌۭ كَرِيمٌۭ",
    "translationText": "It is a noble Quran."
  },
  {
    "surahId": 56,
    "ayahNumber": 78,
    "arabicText": "فِى كِتَٰبٍۢ مَّكْنُونٍۢ",
    "translationText": "In a well-protected Book."
  },
  {
    "surahId": 56,
    "ayahNumber": 79,
    "arabicText": "لَّا يَمَسُّهُۥٓ إِلَّا ٱلْمُطَهَّرُونَ",
    "translationText": "None can grasp it except the purified."
  },
  {
    "surahId": 56,
    "ayahNumber": 80,
    "arabicText": "تَنزِيلٌۭ مِّن رَّبِّ ٱلْعَٰلَمِينَ",
    "translationText": "A revelation from the Lord of the Worlds."
  },
  {
    "surahId": 56,
    "ayahNumber": 81,
    "arabicText": "أَفَبِهَٰذَا ٱلْحَدِيثِ أَنتُم مُّدْهِنُونَ",
    "translationText": "Is it this discourse that you take so lightly?"
  },
  {
