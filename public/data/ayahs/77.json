[
  {
    "surahId": 77,
    "ayahNumber": 1,
    "arabicText": "وَٱلْمُرْسَلَٰتِ عُرْفًۭا",
    "translationText": "By those unleashed in succession."
  },
  {
    "surahId": 77,
    "ayahNumber": 2,
    "arabicText": "فَٱلْعَٰصِفَٰتِ عَصْفًۭا",
    "translationText": "Storming turbulently."
  },
  {
    "surahId": 77,
    "ayahNumber": 3,
    "arabicText": "وَٱلنَّٰشِرَٰتِ نَشْرًۭا",
    "translationText": "Scattering far and wide."
  },
  {
    "surahId": 77,
    "ayahNumber": 4,
    "arabicText": "فَٱلْفَٰرِقَٰتِ فَرْقًۭا",
    "translationText": "Separating decisively."
  },
  {
    "surahId": 77,
    "ayahNumber": 5,
    "arabicText": "فَٱلْمُلْقِيَٰتِ ذِكْرًا",
    "translationText": "Delivering a message."
  },
  {
    "surahId": 77,
    "ayahNumber": 6,
    "arabicText": "عُذْرًا أَوْ نُذْرًا",
    "translationText": "Excusing or warning."
  },
  {
    "surahId": 77,
    "ayahNumber": 7,
    "arabicText": "إِنَّمَا تُوعَدُونَ لَوَٰقِعٌۭ",
    "translationText": "Surely what you are promised will happen."
  },
  {
    "surahId": 77,
    "ayahNumber": 8,
    "arabicText": "فَإِذَا ٱلنُّجُومُ طُمِسَتْ",
    "translationText": "When the stars are obliterated."
  },
  {
    "surahId": 77,
    "ayahNumber": 9,
    "arabicText": "وَإِذَا ٱلسَّمَآءُ فُرِجَتْ",
    "translationText": "And the sky is fractured."
  },
  {
    "surahId": 77,
    "ayahNumber": 10,
    "arabicText": "وَإِذَا ٱلْجِبَالُ نُسِفَتْ",
    "translationText": "And the mountains are blown away."
  },
  {
    "surahId": 77,
    "ayahNumber": 11,
    "arabicText": "وَإِذَا ٱلرُّسُلُ أُقِّتَتْ",
    "translationText": "And the messengers are alerted."
  },
  {
    "surahId": 77,
    "ayahNumber": 12,
    "arabicText": "لِأَىِّ يَوْمٍ أُجِّلَتْ",
    "translationText": "Until which day is it deferred?"
  },
  {
    "surahId": 77,
    "ayahNumber": 13,
    "arabicText": "لِيَوْمِ ٱلْفَصْلِ",
    "translationText": "Until the Day of Decision."
  },
  {
    "surahId": 77,
    "ayahNumber": 14,
    "arabicText": "وَمَآ أَدْرَىٰكَ مَا يَوْمُ ٱلْفَصْلِ",
    "translationText": "And what will teach you what the Day of Decision is?"
  },
  {
    "surahId": 77,
    "ayahNumber": 15,
    "arabicText": "وَيْلٌۭ يَوْمَئِذٍۢ لِّلْمُكَذِّبِينَ",
    "translationText": "Woe on that Day to the liars."
  },
  {
    "surahId": 77,
    "ayahNumber": 16,
    "arabicText": "أَلَمْ نُهْلِكِ ٱلْأَوَّلِينَ",
    "translationText": "Did We not destroy the ancients?"
  },
  {
    "surahId": 77,
    "ayahNumber": 17,
    "arabicText": "ثُمَّ نُتْبِعُهُمُ ٱلْءَاخِرِينَ",
    "translationText": "Then succeeded them with the others?"
  },
  {
    "surahId": 77,
    "ayahNumber": 18,
    "arabicText": "كَذَٰلِكَ نَفْعَلُ بِٱلْمُجْرِمِينَ",
    "translationText": "This is how We deal with the guilty."
  },
  {
    "surahId": 77,
    "ayahNumber": 19,
    "arabicText": "وَيْلٌۭ يَوْمَئِذٍۢ لِّلْمُكَذِّبِينَ",
    "translationText": "Woe on that Day to the rejecters."
  },
  {
    "surahId": 77,
    "ayahNumber": 20,
    "arabicText": "أَلَمْ نَخْلُقكُّم مِّن مَّآءٍۢ مَّهِينٍۢ",
    "translationText": "Did We not create you from an insignificant fluid?"
  },
  {
    "surahId": 77,
    "ayahNumber": 21,
    "arabicText": "فَجَعَلْنَٰهُ فِى قَرَارٍۢ مَّكِينٍ",
    "translationText": "Then lodged it in a secure place?"
  },
  {
    "surahId": 77,
    "ayahNumber": 22,
    "arabicText": "إِلَىٰ قَدَرٍۢ مَّعْلُومٍۢ",
    "translationText": "For a known term?"
  },
  {
    "surahId": 77,
    "ayahNumber": 23,
    "arabicText": "فَقَدَرْنَا فَنِعْمَ ٱلْقَٰدِرُونَ",
    "translationText": "We measured precisely. We are the best to measure."
  },
  {
    "surahId": 77,
    "ayahNumber": 24,
    "arabicText": "وَيْلٌۭ يَوْمَئِذٍۢ لِّلْمُكَذِّبِينَ",
    "translationText": "Woe on that Day to the falsifiers."
  },
  {
    "surahId": 77,
    "ayahNumber": 25,
    "arabicText": "أَلَمْ نَجْعَلِ ٱلْأَرْضَ كِفَاتًا",
    "translationText": "Did We not make the earth a homestead?"
  },
  {
    "surahId": 77,
    "ayahNumber": 26,
    "arabicText": "أَحْيَآءًۭ وَأَمْوَٰتًۭا",
    "translationText": "For the living and the dead?"
  },
  {
    "surahId": 77,
    "ayahNumber": 27,
    "arabicText": "وَجَعَلْنَا فِيهَا رَوَٰسِىَ شَٰمِخَٰتٍۢ وَأَسْقَيْنَٰكُم مَّآءًۭ فُرَاتًۭا",
    "translationText": "And set on it lofty mountains, and given you pure water to drink?"
  },
  {
    "surahId": 77,
    "ayahNumber": 28,
    "arabicText": "وَيْلٌۭ يَوْمَئِذٍۢ لِّلْمُكَذِّبِينَ",
    "translationText": "Woe on that Day to the deniers."
  },
  {
    "surahId": 77,
    "ayahNumber": 29,
    "arabicText": "ٱنطَلِقُوٓا۟ إِلَىٰ مَا كُنتُم بِهِۦ تُكَذِّبُونَ",
    "translationText": "\"Proceed to what you used to deny.\""
  },
  {
    "surahId": 77,
    "ayahNumber": 30,
    "arabicText": "ٱنطَلِقُوٓا۟ إِلَىٰ ظِلٍّۢ ذِى ثَلَٰثِ شُعَبٍۢ",
    "translationText": "\"Proceed to a shadow of three different masses.\""
  },
  {
    "surahId": 77,
    "ayahNumber": 31,
    "arabicText": "لَّا ظَلِيلٍۢ وَلَا يُغْنِى مِنَ ٱللَّهَبِ",
    "translationText": "Offering no shade, and unavailing against the flames."
  },
  {
    "surahId": 77,
    "ayahNumber": 32,
    "arabicText": "إِنَّهَا تَرْمِى بِشَرَرٍۢ كَٱلْقَصْرِ",
    "translationText": "It shoots sparks as castles."
  },
  {
    "surahId": 77,
    "ayahNumber": 33,
    "arabicText": "كَأَنَّهُۥ جِمَٰلَتٌۭ صُفْرٌۭ",
    "translationText": "As if they were yellow camels."
  },
  {
    "surahId": 77,
    "ayahNumber": 34,
    "arabicText": "وَيْلٌۭ يَوْمَئِذٍۢ لِّلْمُكَذِّبِينَ",
    "translationText": "Woe on that Day to the liars."
  },
  {
    "surahId": 77,
    "ayahNumber": 35,
    "arabicText": "هَٰذَا يَوْمُ لَا يَنطِقُونَ",
    "translationText": "This is a Day when they will not speak."
  },
  {
    "surahId": 77,
    "ayahNumber": 36,
    "arabicText": "وَلَا يُؤْذَنُ لَهُمْ فَيَعْتَذِرُونَ",
    "translationText": "And they will not be allowed to apologize."
  },
  {
    "surahId": 77,
    "ayahNumber": 37,
    "arabicText": "وَيْلٌۭ يَوْمَئِذٍۢ لِّلْمُكَذِّبِينَ",
    "translationText": "Woe on that Day to the rejecters."
  },
  {
    "surahId": 77,
    "ayahNumber": 38,
    "arabicText": "هَٰذَا يَوْمُ ٱلْفَصْلِ ۖ جَمَعْنَٰكُمْ وَٱلْأَوَّلِينَ",
    "translationText": "This is the Day of Separation; We have gathered you, together with the ancients."
  },
  {
    "surahId": 77,
    "ayahNumber": 39,
    "arabicText": "فَإِن كَانَ لَكُمْ كَيْدٌۭ فَكِيدُونِ",
    "translationText": "So if you have a strategy, use it against Me."
  },
  {
    "surahId": 77,
    "ayahNumber": 40,
    "arabicText": "وَيْلٌۭ يَوْمَئِذٍۢ لِّلْمُكَذِّبِينَ",
    "translationText": "Woe on that Day to the falsifiers."
  },
  {
    "surahId": 77,
    "ayahNumber": 41,
    "arabicText": "إِنَّ ٱلْمُتَّقِينَ فِى ظِلَٰلٍۢ وَعُيُونٍۢ",
    "translationText": "The righteous will be amidst shades and fountains."
  },
  {
    "surahId": 77,
    "ayahNumber": 42,
    "arabicText": "وَفَوَٰكِهَ مِمَّا يَشْتَهُونَ",
    "translationText": "And fruits as they desire."
  },
  {
    "surahId": 77,
    "ayahNumber": 43,
    "arabicText": "كُلُوا۟ وَٱشْرَبُوا۟ هَنِيٓـًٔۢا بِمَا كُنتُمْ تَعْمَلُونَ",
    "translationText": "\"Eat and drink pleasantly, for what you used to do.\""
  },
  {
    "surahId": 77,
    "ayahNumber": 44,
    "arabicText": "إِنَّا كَذَٰلِكَ نَجْزِى ٱلْمُحْسِنِينَ",
    "translationText": "This is how We reward the doers of good."
  },
  {
    "surahId": 77,
    "ayahNumber": 45,
    "arabicText": "وَيْلٌۭ يَوْمَئِذٍۢ لِّلْمُكَذِّبِينَ",
    "translationText": "Woe on that Day to the deniers."
  },
  {
    "surahId": 77,
    "ayahNumber": 46,
    "arabicText": "كُلُوا۟ وَتَمَتَّعُوا۟ قَلِيلًا إِنَّكُم مُّجْرِمُونَ",
    "translationText": "\"Eat and enjoy yourselves a little; you are indeed criminals.\""
  },
  {
    "surahId": 77,
    "ayahNumber": 47,
    "arabicText": "وَيْلٌۭ يَوْمَئِذٍۢ لِّلْمُكَذِّبِينَ",
    "translationText": "Woe on that Day to the liars."
  },
  {
    "surahId": 77,
    "ayahNumber": 48,
    "arabicText": "وَإِذَا قِيلَ لَهُمُ ٱرْكَعُوا۟ لَا يَرْكَعُونَ",
    "translationText": "And when it is said to them, \"Kneel\", they do not kneel."
  },
  {
    "surahId": 77,
    "ayahNumber": 49,
    "arabicText": "وَيْلٌۭ يَوْمَئِذٍۢ لِّلْمُكَذِّبِينَ",
    "translationText": "Woe on that Day to the rejecters."
  },
  {
    "surahId": 77,
    "ayahNumber": 50,
    "arabicText": "فَبِأَىِّ حَدِيثٍۭ بَعْدَهُۥ يُؤْمِنُونَ",
    "translationText": "In what message, beyond this, will they believe?"
  }
]