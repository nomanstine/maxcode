[
  {
    "surahId": 88,
    "ayahNumber": 1,
    "arabicText": "هَلْ أَتَىٰكَ حَدِيثُ ٱلْغَٰشِيَةِ",
    "translationText": "Has there come to you the news of the overwhelming?"
  },
  {
    "surahId": 88,
    "ayahNumber": 2,
    "arabicText": "وُجُوهٌۭ يَوْمَئِذٍ خَٰشِعَةٌ",
    "translationText": "Faces on that Day will be shamed."
  },
  {
    "surahId": 88,
    "ayahNumber": 3,
    "arabicText": "عَامِلَةٌۭ نَّاصِبَةٌۭ",
    "translationText": "Laboring and exhausted."
  },
  {
    "surahId": 88,
    "ayahNumber": 4,
    "arabicText": "تَصْلَىٰ نَارًا حَامِيَةًۭ",
    "translationText": "Roasting in a scorching Fire."
  },
  {
    "surahId": 88,
    "ayahNumber": 5,
    "arabicText": "تُسْقَىٰ مِنْ عَيْنٍ ءَانِيَةٍۢ",
    "translationText": "Given to drink from a flaming spring."
  },
  {
    "surahId": 88,
    "ayahNumber": 6,
    "arabicText": "لَّيْسَ لَهُمْ طَعَامٌ إِلَّا مِن ضَرِيعٍۢ",
    "translationText": "They will have no food except thorns."
  },
  {
    "surahId": 88,
    "ayahNumber": 7,
    "arabicText": "لَّا يُسْمِنُ وَلَا يُغْنِى مِن جُوعٍۢ",
    "translationText": "That neither nourishes, nor satisfies hunger."
  },
  {
    "surahId": 88,
    "ayahNumber": 8,
    "arabicText": "وُجُوهٌۭ يَوْمَئِذٍۢ نَّاعِمَةٌۭ",
    "translationText": "Faces on that Day will be joyful."
  },
  {
    "surahId": 88,
    "ayahNumber": 9,
    "arabicText": "لِّسَعْيِهَا رَاضِيَةٌۭ",
    "translationText": "Satisfied with their endeavor."
  },
  {
    "surahId": 88,
    "ayahNumber": 10,
    "arabicText": "فِى جَنَّةٍ عَالِيَةٍۢ",
    "translationText": "In a lofty Garden."
  },
  {
    "surahId": 88,
    "ayahNumber": 11,
    "arabicText": "لَّا تَسْمَعُ فِيهَا لَٰغِيَةًۭ",
    "translationText": "In it you will hear no nonsense."
  },
  {
    "surahId": 88,
    "ayahNumber": 12,
    "arabicText": "فِيهَا عَيْنٌۭ جَارِيَةٌۭ",
    "translationText": "In it is a flowing spring."
  },
  {
    "surahId": 88,
    "ayahNumber": 13,
    "arabicText": "فِيهَا سُرُرٌۭ مَّرْفُوعَةٌۭ",
    "translationText": "In it are raised beds."
  },
  {
    "surahId": 88,
    "ayahNumber": 14,
    "arabicText": "وَأَكْوَابٌۭ مَّوْضُوعَةٌۭ",
    "translationText": "And cups set in place."
  },
  {
    "surahId": 88,
    "ayahNumber": 15,
    "arabicText": "وَنَمَارِقُ مَصْفُوفَةٌۭ",
    "translationText": "And cushions set in rows."
  },
  {
    "surahId": 88,
    "ayahNumber": 16,
    "arabicText": "وَزَرَابِىُّ مَبْثُوثَةٌ",
    "translationText": "And carpets spread around."
  },
  {
    "surahId": 88,
    "ayahNumber": 17,
    "arabicText": "أَفَلَا يَنظُرُونَ إِلَى ٱلْإِبِلِ كَيْفَ خُلِقَتْ",
    "translationText": "Do they not look at the camels-how they are created?"
  },
  {
    "surahId": 88,
    "ayahNumber": 18,
    "arabicText": "وَإِلَى ٱلسَّمَآءِ كَيْفَ رُفِعَتْ",
    "translationText": "And at the sky-how it is raised?"
  },
  {
    "surahId": 88,
    "ayahNumber": 19,
    "arabicText": "وَإِلَى ٱلْجِبَالِ كَيْفَ نُصِبَتْ",
    "translationText": "And at the mountains-how they are installed?"
  },
  {
    "surahId": 88,
    "ayahNumber": 20,
    "arabicText": "وَإِلَى ٱلْأَرْضِ كَيْفَ سُطِحَتْ",
    "translationText": "And at the earth-how it is spread out?"
  },
  {
    "surahId": 88,
    "ayahNumber": 21,
    "arabicText": "فَذَكِّرْ إِنَّمَآ أَنتَ مُذَكِّرٌۭ",
    "translationText": "So remind. You are only a reminder."
  },
  {
    "surahId": 88,
    "ayahNumber": 22,
    "arabicText": "لَّسْتَ عَلَيْهِم بِمُصَيْطِرٍ",
    "translationText": "You have no control over them."
  },
  {
    "surahId": 88,
    "ayahNumber": 23,
    "arabicText": "إِلَّا مَن تَوَلَّىٰ وَكَفَرَ",
    "translationText": "But whoever turns away and disbelieves."
  },
  {
    "surahId": 88,
    "ayahNumber": 24,
    "arabicText": "فَيُعَذِّبُهُ ٱللَّهُ ٱلْعَذَابَ ٱلْأَكْبَرَ",
    "translationText": "God will punish him with the greatest punishment."
  },
  {
    "surahId": 88,
    "ayahNumber": 25,
    "arabicText": "إِنَّ إِلَيْنَآ إِيَابَهُمْ",
    "translationText": "To Us is their return."
  },
  {
    "surahId": 88,
    "ayahNumber": 26,
    "arabicText": "ثُمَّ إِنَّ عَلَيْنَا حِسَابَهُم",
    "translationText": "Then upon Us rests their reckoning."
  }
]