[
  {
    "surahId": 81,
    "ayahNumber": 1,
    "arabicText": "إِذَا ٱلشَّمْسُ كُوِّرَتْ",
    "translationText": "When the sun is rolled up."
  },
  {
    "surahId": 81,
    "ayahNumber": 2,
    "arabicText": "وَإِذَا ٱلنُّجُومُ ٱنكَدَرَتْ",
    "translationText": "When the stars are dimmed."
  },
  {
    "surahId": 81,
    "ayahNumber": 3,
    "arabicText": "وَإِذَا ٱلْجِبَالُ سُيِّرَتْ",
    "translationText": "When the mountains are set in motion."
  },
  {
    "surahId": 81,
    "ayahNumber": 4,
    "arabicText": "وَإِذَا ٱلْعِشَارُ عُطِّلَتْ",
    "translationText": "When the relationships are suspended."
  },
  {
    "surahId": 81,
    "ayahNumber": 5,
    "arabicText": "وَإِذَا ٱلْوُحُوشُ حُشِرَتْ",
    "translationText": "When the beasts are gathered."
  },
  {
    "surahId": 81,
    "ayahNumber": 6,
    "arabicText": "وَإِذَا ٱلْبِحَارُ سُجِّرَتْ",
    "translationText": "When the oceans are set aflame."
  },
  {
    "surahId": 81,
    "ayahNumber": 7,
    "arabicText": "وَإِذَا ٱلنُّفُوسُ زُوِّجَتْ",
    "translationText": "When the souls are paired."
  },
  {
    "surahId": 81,
    "ayahNumber": 8,
    "arabicText": "وَإِذَا ٱلْمَوْءُۥدَةُ سُئِلَتْ",
    "translationText": "When the girl, buried alive, is asked:"
  },
  {
    "surahId": 81,
    "ayahNumber": 9,
    "arabicText": "بِأَىِّ ذَنۢبٍۢ قُتِلَتْ",
    "translationText": "For what crime was she killed?"
  },
  {
    "surahId": 81,
    "ayahNumber": 10,
    "arabicText": "وَإِذَا ٱلصُّحُفُ نُشِرَتْ",
    "translationText": "When the records are made public."
  },
  {
    "surahId": 81,
    "ayahNumber": 11,
    "arabicText": "وَإِذَا ٱلسَّمَآءُ كُشِطَتْ",
    "translationText": "When the sky is peeled away."
  },
  {
    "surahId": 81,
    "ayahNumber": 12,
    "arabicText": "وَإِذَا ٱلْجَحِيمُ سُعِّرَتْ",
    "translationText": "When the Fire is set ablaze."
  },
  {
    "surahId": 81,
    "ayahNumber": 13,
    "arabicText": "وَإِذَا ٱلْجَنَّةُ أُزْلِفَتْ",
    "translationText": "When Paradise is brought near."
  },
  {
    "surahId": 81,
    "ayahNumber": 14,
    "arabicText": "عَلِمَتْ نَفْسٌۭ مَّآ أَحْضَرَتْ",
    "translationText": "Each soul will know what it has readied."
  },
  {
    "surahId": 81,
    "ayahNumber": 15,
    "arabicText": "فَلَآ أُقْسِمُ بِٱلْخُنَّسِ",
    "translationText": "I swear by the galaxies."
  },
  {
    "surahId": 81,
    "ayahNumber": 16,
    "arabicText": "ٱلْجَوَارِ ٱلْكُنَّسِ",
    "translationText": "Precisely running their courses."
  },
  {
    "surahId": 81,
    "ayahNumber": 17,
    "arabicText": "وَٱلَّيْلِ إِذَا عَسْعَسَ",
    "translationText": "And by the night as it recedes."
  },
  {
    "surahId": 81,
    "ayahNumber": 18,
    "arabicText": "وَٱلصُّبْحِ إِذَا تَنَفَّسَ",
    "translationText": "And by the morn as it breathes."
  },
  {
    "surahId": 81,
    "ayahNumber": 19,
    "arabicText": "إِنَّهُۥ لَقَوْلُ رَسُولٍۢ كَرِيمٍۢ",
    "translationText": "This is the speech of a noble messenger."
  },
  {
    "surahId": 81,
    "ayahNumber": 20,
    "arabicText": "ذِى قُوَّةٍ عِندَ ذِى ٱلْعَرْشِ مَكِينٍۢ",
    "translationText": "Endowed with power, eminent with the Lord of the Throne."
  },
  {
    "surahId": 81,
    "ayahNumber": 21,
    "arabicText": "مُّطَاعٍۢ ثَمَّ أَمِينٍۢ",
    "translationText": "Obeyed and honest."
  },
  {
    "surahId": 81,
    "ayahNumber": 22,
    "arabicText": "وَمَا صَاحِبُكُم بِمَجْنُونٍۢ",
    "translationText": "Your friend is not possessed."
  },
  {
    "surahId": 81,
    "ayahNumber": 23,
    "arabicText": "وَلَقَدْ رَءَاهُ بِٱلْأُفُقِ ٱلْمُبِينِ",
    "translationText": "He saw him on the luminous horizon."
  },
  {
    "surahId": 81,
    "ayahNumber": 24,
    "arabicText": "وَمَا هُوَ عَلَى ٱلْغَيْبِ بِضَنِينٍۢ",
    "translationText": "And He does not withhold knowledge of the Unseen."
  },
  {
    "surahId": 81,
    "ayahNumber": 25,
    "arabicText": "وَمَا هُوَ بِقَوْلِ شَيْطَٰنٍۢ رَّجِيمٍۢ",
    "translationText": "And it is not the word of an accursed devil."
  },
  {
    "surahId": 81,
    "ayahNumber": 26,
    "arabicText": "فَأَيْنَ تَذْهَبُونَ",
    "translationText": "So where are you heading?"
  },
  {
    "surahId": 81,
    "ayahNumber": 27,
    "arabicText": "إِنْ هُوَ إِلَّا ذِكْرٌۭ لِّلْعَٰلَمِينَ",
    "translationText": "It is only a Reminder to all mankind."
  },
  {
    "surahId": 81,
    "ayahNumber": 28,
    "arabicText": "لِمَن شَآءَ مِنكُمْ أَن يَسْتَقِيمَ",
    "translationText": "To whoever of you wills to go straight."
  },
  {
    "surahId": 81,
    "ayahNumber": 29,
    "arabicText": "وَمَا تَشَآءُونَ إِلَّآ أَن يَشَآءَ ٱللَّهُ رَبُّ ٱلْعَٰلَمِينَ",
    "translationText": "But you cannot will, unless God wills-The Lord of the Worlds."
  }
]