[
  {
    "surahId": 105,
    "ayahNumber": 1,
    "arabicText": "أَلَمْ تَرَ كَيْفَ فَعَلَ رَبُّكَ بِأَصْحَٰبِ ٱلْفِيلِ",
    "translationText": "Have you not considered how your Lord dealt with the People of the Elephant?"
  },
  {
    "surahId": 105,
    "ayahNumber": 2,
    "arabicText": "أَلَمْ يَجْعَلْ كَيْدَهُمْ فِى تَضْلِيلٍۢ",
    "translationText": "Did He not make their plan go wrong?"
  },
  {
    "surahId": 105,
    "ayahNumber": 3,
    "arabicText": "وَأَرْسَلَ عَلَيْهِمْ طَيْرًا أَبَابِيلَ",
    "translationText": "He sent against them swarms of birds."
  },
  {
    "surahId": 105,
    "ayahNumber": 4,
    "arabicText": "تَرْمِيهِم بِحِجَارَةٍۢ مِّن سِجِّيلٍۢ",
    "translationText": "Throwing at them rocks of baked clay."
  },
  {
    "surahId": 105,
    "ayahNumber": 5,
    "arabicText": "فَجَعَلَهُمْ كَعَصْفٍۢ مَّأْكُولٍۭ",
    "translationText": "Leaving them like chewed-up leaves."
  }
]