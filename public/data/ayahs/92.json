    "ayahNumber": 1,
    "arabicText": "وَٱلَّيْلِ إِذَا يَغْشَىٰ",
    "translationText": "By the night as it covers."
  },
  {
    "surahId": 92,
    "ayahNumber": 2,
    "arabicText": "وَٱلنَّهَارِ إِذَا تَجَلَّىٰ",
    "translationText": "And the day as it reveals."
  },
  {
    "surahId": 92,
    "ayahNumber": 3,
    "arabicText": "وَمَا خَلَقَ ٱلذَّكَرَ وَٱلْأُنثَىٰٓ",
    "translationText": "And He who created the male and the female."
  },
  {
    "surahId": 92,
    "ayahNumber": 4,
    "arabicText": "إِنَّ سَعْيَكُمْ لَشَتَّىٰ",
    "translationText": "Your endeavors are indeed diverse."
  },
  {
    "surahId": 92,
    "ayahNumber": 5,
    "arabicText": "فَأَمَّا مَنْ أَعْطَىٰ وَٱتَّقَىٰ",
    "translationText": "As for him who gives and is righteous."
  },
  {
    "surahId": 92,
    "ayahNumber": 6,
    "arabicText": "وَصَدَّقَ بِٱلْحُسْنَىٰ",
    "translationText": "And confirms goodness."
  },
  {
    "surahId": 92,
    "ayahNumber": 7,
    "arabicText": "فَسَنُيَسِّرُهُۥ لِلْيُسْرَىٰ",
    "translationText": "We will ease his way towards ease."
  },
  {
    "surahId": 92,
    "ayahNumber": 8,
    "arabicText": "وَأَمَّا مَنۢ بَخِلَ وَٱسْتَغْنَىٰ",
    "translationText": "But as for him who is stingy and complacent."
  },
  {
    "surahId": 92,
    "ayahNumber": 9,
    "arabicText": "وَكَذَّبَ بِٱلْحُسْنَىٰ",
    "translationText": "And denies goodness."
  },
  {
    "surahId": 92,
    "ayahNumber": 10,
    "arabicText": "فَسَنُيَسِّرُهُۥ لِلْعُسْرَىٰ",
    "translationText": "We will ease his way towards difficulty."
  },
  {
    "surahId": 92,
    "ayahNumber": 11,
    "arabicText": "وَمَا يُغْنِى عَنْهُ مَالُهُۥٓ إِذَا تَرَدَّىٰٓ",
    "translationText": "And his money will not avail him when he plummets."
  },
  {
    "surahId": 92,
    "ayahNumber": 12,
    "arabicText": "إِنَّ عَلَيْنَا لَلْهُدَىٰ",
    "translationText": "It is upon Us to guide."
  },
  {
    "surahId": 92,
    "ayahNumber": 13,
    "arabicText": "وَإِنَّ لَنَا لَلْءَاخِرَةَ وَٱلْأُولَىٰ",
    "translationText": "And to Us belong the Last and the First."
  },
  {
    "surahId": 92,
    "ayahNumber": 14,
    "arabicText": "فَأَنذَرْتُكُمْ نَارًۭا تَلَظَّىٰ",
    "translationText": "I have warned you of a Fierce Blaze."
  },
  {
    "surahId": 92,
    "ayahNumber": 15,
    "arabicText": "لَا يَصْلَىٰهَآ إِلَّا ٱلْأَشْقَى",
    "translationText": "None will burn in it except the very wicked."
  },
  {
    "surahId": 92,
    "ayahNumber": 16,
    "arabicText": "ٱلَّذِى كَذَّبَ وَتَوَلَّىٰ",
    "translationText": "He who denies and turns away."
  },
  {
    "surahId": 92,
    "ayahNumber": 17,
    "arabicText": "وَسَيُجَنَّبُهَا ٱلْأَتْقَى",
    "translationText": "But the devout will avoid it."
  },
  {
    "surahId": 92,
    "ayahNumber": 18,
    "arabicText": "ٱلَّذِى يُؤْتِى مَالَهُۥ يَتَزَكَّىٰ",
    "translationText": "He who gives his money to become pure."
  },
  {
    "surahId": 92,
    "ayahNumber": 19,
    "arabicText": "وَمَا لِأَحَدٍ عِندَهُۥ مِن نِّعْمَةٍۢ تُجْزَىٰٓ",
    "translationText": "Seeking no favor in return."
  },
  {
    "surahId": 92,
    "ayahNumber": 20,
    "arabicText": "إِلَّا ٱبْتِغَآءَ وَجْهِ رَبِّهِ ٱلْأَعْلَىٰ",
    "translationText": "Only seeking the acceptance of his Lord, the Most High."
  },
  {
    "surahId": 92,
    "ayahNumber": 21,
    "arabicText": "وَلَسَوْفَ يَرْضَىٰ",
    "translationText": "And he will be satisfied."
  }
