[
  {
    "surahId": 86,
    "ayahNumber": 1,
    "arabicText": "وَٱلسَّمَآءِ وَٱلطَّارِقِ",
    "translationText": "By the sky and at-Tariq."
  },
  {
    "surahId": 86,
    "ayahNumber": 2,
    "arabicText": "وَمَآ أَدْرَىٰكَ مَا ٱلطَّارِقُ",
    "translationText": "But what will let you know what at-Tariq is?"
  },
  {
    "surahId": 86,
    "ayahNumber": 3,
    "arabicText": "ٱلنَّجْمُ ٱلثَّاقِبُ",
    "translationText": "The Piercing Star."
  },
  {
    "surahId": 86,
    "ayahNumber": 4,
    "arabicText": "إِن كُلُّ نَفْسٍۢ لَّمَّا عَلَيْهَا حَافِظٌۭ",
    "translationText": "There is no soul without a Protector over it."
  },
  {
    "surahId": 86,
    "ayahNumber": 5,
    "arabicText": "فَلْيَنظُرِ ٱلْإِنسَٰنُ مِمَّ خُلِقَ",
    "translationText": "Let man consider what he was created from."
  },
  {
    "surahId": 86,
    "ayahNumber": 6,
    "arabicText": "خُلِقَ مِن مَّآءٍۢ دَافِقٍۢ",
    "translationText": "He was created from gushing liquid."
  },
  {
    "surahId": 86,
    "ayahNumber": 7,
    "arabicText": "يَخْرُجُ مِنۢ بَيْنِ ٱلصُّلْبِ وَٱلتَّرَآئِبِ",
    "translationText": "Issuing from between the backbone and the breastbones."
  },
  {
    "surahId": 86,
    "ayahNumber": 8,
    "arabicText": "إِنَّهُۥ عَلَىٰ رَجْعِهِۦ لَقَادِرٌۭ",
    "translationText": "He is certainly able to return him."
  },
  {
    "surahId": 86,
    "ayahNumber": 9,
    "arabicText": "يَوْمَ تُبْلَى ٱلسَّرَآئِرُ",
    "translationText": "On the Day when the secrets are disclosed."
  },
  {
    "surahId": 86,
    "ayahNumber": 10,
    "arabicText": "فَمَا لَهُۥ مِن قُوَّةٍۢ وَلَا نَاصِرٍۢ",
    "translationText": "He will have no strength, and no supporter."
  },
  {
    "surahId": 86,
    "ayahNumber": 11,
    "arabicText": "وَٱلسَّمَآءِ ذَاتِ ٱلرَّجْعِ",
    "translationText": "By the sky that returns."
  },
  {
    "surahId": 86,
    "ayahNumber": 12,
    "arabicText": "وَٱلْأَرْضِ ذَاتِ ٱلصَّدْعِ",
    "translationText": "And the earth that cracks open."
  },
  {
    "surahId": 86,
    "ayahNumber": 13,
    "arabicText": "إِنَّهُۥ لَقَوْلٌۭ فَصْلٌۭ",
    "translationText": "It is a Decisive Word."
  },
  {
    "surahId": 86,
    "ayahNumber": 14,
    "arabicText": "وَمَا هُوَ بِٱلْهَزْلِ",
    "translationText": "It is no joke."
  },
  {
    "surahId": 86,
    "ayahNumber": 15,
    "arabicText": "إِنَّهُمْ يَكِيدُونَ كَيْدًۭا",
    "translationText": "They plot and scheme."
  },
  {
    "surahId": 86,
    "ayahNumber": 16,
    "arabicText": "وَأَكِيدُ كَيْدًۭا",
    "translationText": "But I plot and scheme."
  },
  {
    "surahId": 86,
    "ayahNumber": 17,
    "arabicText": "فَمَهِّلِ ٱلْكَٰفِرِينَ أَمْهِلْهُمْ رُوَيْدًۢا",
    "translationText": "Therefore, give the blasphemers respite, a brief respite."
  }
]